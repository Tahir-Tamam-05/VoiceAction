# NOTE: AI features require NO API key. All intelligence (note structuring,
# semantic search, connections, insights) runs locally on-device via a
# quantized embedding model downloaded once and cached by the browser.

# ─── Firebase ────────────────────────────────────────────────────────────────
# Required for authentication (Google Sign-In, Email/Password) and cloud sync.
# Create a project at: https://console.firebase.google.com
# Then go to Project Settings → Your apps → Web app → Config
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxxxxxxxxx"

# ─── Development only ────────────────────────────────────────────────────────
# Set to true to skip Firebase auth and log in as a mock user automatically.
# Has NO effect in production builds (PROD=true). Safe to leave unset.
# VITE_DEV_BYPASS_AUTH=true

# ─── Optional ────────────────────────────────────────────────────────────────
# APP_URL is used for OAuth callbacks if hosting on Cloud Run.
APP_URL="http://localhost:5173"

# ─── Error Monitoring (Sentry) ────────────────────────────────────────────────
# Optional. Install @sentry/react and uncomment the init block in monitoring.ts.
# Get your DSN at: https://sentry.io
# VITE_SENTRY_DSN="https://your-dsn@sentry.io/your-project-id"
